# MiniMax 开放平台 API Key（仓位截图识别必填）
MINIMAX_API_KEY=

# 区域：cn（国内 api.minimaxi.com）或 global（api.minimax.io）
MINIMAX_REGION=cn

# 可选：覆盖 API Base URL
# MINIMAX_BASE_URL=

# 可选：mmx 可执行文件路径；留空则依次尝试 node_modules/.bin 与 PATH
# MINIMAX_MMX_BIN=

# 仓位识别后端：auto（有 mmx 用 mmx，否则 httpx）| mmx | httpx
# MINIMAX_BACKEND=auto

# 可选：NiceGUI 用户存储加密密钥（生产环境请设置随机长字符串）
# NICEGUI_STORAGE_SECRET=

# 可将打码/裁剪后的持仓截图放在 screenshots/ 目录供本地对照与手工回归；
# 勿将含完整账号、资产信息的原图提交到公开 git 仓库。
