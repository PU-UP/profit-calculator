# 从 MiniMax 开放平台控制台复制（Token Plan）。本仓库调用 mmx 时会传入 --api-key（来自本文件），
# 与 ~/.mmx/config.json 脱钩；若不再需要全局保存的密钥可执行：mmx auth logout --yes
MINIMAX_API_KEY=

# 区域：cn（国内 api.minimaxi.com）或 global（api.minimax.io）
MINIMAX_REGION=cn

# 可选：覆盖 API Base URL（与 mmx --base-url 一致，留空则交给 CLI 按 region 选择）
# MINIMAX_BASE_URL=

# 可选：mmx 可执行文件路径；留空则依次尝试 node_modules/.bin 与 PATH
# MINIMAX_MMX_BIN=

# 可将打码/裁剪后的持仓截图放在 screenshots/ 目录供本地对照与手工回归；
# 勿将含完整账号、资产信息的原图提交到公开 git 仓库。
